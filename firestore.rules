rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // TALLERES (Datos operativos del taller)
    // ============================================================
    // El dueño se autentica con email/password (user.uid == workshopId).
    // Los empleados en el taller comparten el login de Firebase del dueño.
    match /workshops/{workshopId} {
      // Solo permitimos leer/escribir si el usuario autenticado en Firebase
      // coincide exactamente con el ID del taller (el UID de la cuenta del dueño).
      allow read, write: if request.auth != null && request.auth.uid == workshopId;
    }
    
    // Subcolecciones del taller (clientes, vehículos, presupuestos, etc.)
    match /workshops/{workshopId}/{collection}/{docId} {
      // Bloquea a cualquier usuario que no pertenezca a este taller específico
      allow read, write: if request.auth != null && request.auth.uid == workshopId;
    }
    
    // Subcolecciones anidadas
    match /workshops/{workshopId}/{collection}/{docId}/{subcollection=**} {
      allow read, write: if request.auth != null && request.auth.uid == workshopId;
    }
    
    // ============================================================
    // SOLICITUDES SAAS (Registro de nuevos talleres)
    // ============================================================
    match /saas_requests/{requestId} {
      // Permitir la creación (escritura inicial) a cualquiera (para que los nuevos talleres puedan registrarse)
      allow create: if true;
      
      // Permitir leer y actualizar si conocen el requestId (los solicitantes leen su propio estado)
      allow get, update: if true;
      
      // Solo el correo del administrador de la plataforma puede listar o borrar solicitudes
      allow list, delete: if request.auth != null && request.auth.token.email in ["dvd19981029@gmail.com", "amejia2998@gmail.com"];
    }
    
    // ============================================================
    // PLANES Y CUPONES (Catálogo comercial)
    // ============================================================
    match /saas_plans/{docId} {
      allow read, write: if true;
    }
    match /saas_coupons/{docId} {
      allow read, write: if true;
    }
    
    // ============================================================
    // MÉTRICAS SAAS (Para el super admin)
    // ============================================================
    match /saas_metrics/{document=**} {
      // Solo el correo del administrador de la plataforma puede ver o modificar métricas globales
      allow read, write: if request.auth != null && request.auth.token.email in ["dvd19981029@gmail.com", "amejia2998@gmail.com"];
    }

    // ============================================================
    // LOGS DE APIS DTE (Para el super admin)
    // ============================================================
    match /dte_api_logs/{docId} {
      allow read, write: if request.auth != null && request.auth.token.email in ["dvd19981029@gmail.com", "amejia2998@gmail.com"];
    }
    
  }
}
